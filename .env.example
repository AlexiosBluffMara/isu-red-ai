# ── Required ──────────────────────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Google Cloud (optional) ──────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1

# ── Data paths (defaults work if data/ is populated) ─────────────────
# PDFS_DIR=data/pdfs
# EXTRACTED_DIR=data/extracted
# LANCEDB_DIR=data/lancedb
# PAPERS_DB=data/metadata/papers_database.json

# ── Web server ───────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:8080,http://localhost:3000
# ENABLE_DOCS=1
# PORT=8080

# ── Rate limiting ────────────────────────────────────────────────────
# RATE_LIMIT_RPS=2         # Requests per second (refill rate)
# RATE_LIMIT_BURST=30      # Maximum burst capacity per IP
