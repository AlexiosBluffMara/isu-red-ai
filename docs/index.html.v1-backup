<section class="section section-alt" id="api">
  <div class="container">
    <div class="section-header animate">
      <div class="section-label">Getting Started</div>
      <h2 class="section-title">API Endpoints</h2>
      <p class="section-desc">
        RESTful API for programmatic access to the full research index.
      </p>
    </div>
    <div class="api-grid animate">
      <div class="api-card">
        <div class="api-card-header">
          <span class="api-method post">POST</span>
          <span class="api-path">/api/search</span>
        </div>
        <div class="api-card-body">
          <div class="api-desc">Semantic search across all indexed papers. Returns ranked results with relevance scores.</div>
          <div class="api-code">{
  "query": "rural education outcomes",
  "top_k": 10,
  "filters": {
    "year_min": 2010,
    "department": "Education"
  }
}</div>
        </div>
      </div>
      <div class="api-card">
        <div class="api-card-header">
          <span class="api-method post">POST</span>
          <span class="api-path">/api/ask</span>
        </div>
        <div class="api-card-body">
          <div class="api-desc">RAG-powered Q&A — get synthesized answers with citations from source documents.</div>
          <div class="api-code">{
  "question": "What has ISU published
    about climate impacts on crops?",
  "max_sources": 5
}</div>
        </div>
      </div>
      <div class="api-card">
        <div class="api-card-header">
          <span class="api-method get">GET</span>
          <span class="api-path">/api/stats</span>
        </div>
        <div class="api-card-body">
          <div class="api-desc">Returns pipeline statistics — paper count, chunk count, subject tags, and index metadata.</div>
          <div class="api-code">{
  "total_papers": 13610,
  "total_chunks": 193653,
  "unique_subjects": 12369,
  "db_size_gb": 2.5,
  "temporal_range": [1857, 2026]
}</div>
        </div>
      </div>
      <div class="api-card">
        <div class="api-card-header">
          <span class="api-method get">GET</span>
          <span class="api-path">/api/paper/{id}</span>
        </div>
        <div class="api-card-body">
          <div class="api-desc">Retrieve full metadata and extracted text for a specific paper by its ReD identifier.</div>
          <div class="api-code">{
  "id": "red-12345",
  "title": "Effects of Mindfulness...",
  "year": 2023,
  "department": "Psychology",
  "subjects": ["mindfulness", ...]
}</div>
        </div>
      </div>
    </div>
  </div>
</section>

