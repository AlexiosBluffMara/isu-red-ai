<script>
/* ========== DARK MODE ========== */
const toggle = document.getElementById('themeToggle');
const html = document.documentElement;

function setTheme(theme) {
  html.setAttribute('data-theme', theme);
  toggle.textContent = theme === 'dark' ? '☀️' : '🌙';
  try { localStorage.setItem('isu-red-ai-theme', theme); } catch(e) {}
}

(function initTheme() {
  try {
    const saved = localStorage.getItem('isu-red-ai-theme');
    if (saved) { setTheme(saved); return; }
  } catch(e) {}
  if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
    setTheme('dark');
  }
})();

toggle.addEventListener('click', function() {
  const current = html.getAttribute('data-theme');
  setTheme(current === 'dark' ? 'light' : 'dark');
});

/* ========== MOBILE NAV ========== */
document.getElementById('mobileBtn').addEventListener('click', function() {
  document.getElementById('navLinks').classList.toggle('open');
});

document.querySelectorAll('.nav-links a').forEach(function(link) {
  link.addEventListener('click', function() {
    document.getElementById('navLinks').classList.remove('open');
  });
});

/* ========== SCROLL PROGRESS ========== */
window.addEventListener('scroll', function() {
  var h = document.documentElement;
  var scrollTop = h.scrollTop || document.body.scrollTop;
  var scrollHeight = h.scrollHeight - h.clientHeight;
  var progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
  document.getElementById('scrollProgress').style.width = progress + '%';
});

/* ========== SCROLL ANIMATIONS ========== */
var observer = new IntersectionObserver(function(entries) {
  entries.forEach(function(entry) {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.animate').forEach(function(el) {
  observer.observe(el);
});

/* ========== DEMO SEARCH ========== */
var demoResponses = {
  "What research has ISU conducted on rural education outcomes?": {
    title: "Rural Education Outcomes at Illinois State University",
    meta: "Synthesized from 3 papers · Departments: Education, Sociology · 2018–2024",
    text: "ISU researchers have extensively studied rural education challenges in Central Illinois. Key findings include: (1) rural school districts face a 23% higher teacher turnover rate compared to urban counterparts (Martinez & Chen, 2022), (2) technology-enhanced learning programs showed a statistically significant improvement in standardized test scores among rural 8th graders (Thompson, 2020), and (3) community partnership models developed at ISU's College of Education have been adopted by 14 districts statewide (Williams et al., 2024).",
    tags: ["Rural Education", "Teacher Retention", "EdTech", "Community Partnerships", "K-12"]
  },
  "How has climate change affected Illinois agriculture according to ISU studies?": {
    title: "Climate Impacts on Illinois Agriculture",
    meta: "Synthesized from 4 papers · Department: Agriculture · 2019–2025",
    text: "ISU's Department of Agriculture has documented significant climate-driven shifts in Central Illinois farming. Studies show: (1) a 12-day extension in the growing season since 1990, with increased heat stress events reducing corn yields by an estimated 4–8% in peak years (Roberts & Patel, 2023), (2) shifting precipitation patterns have increased soil erosion risk by 18% across McLean County (Garcia, 2021), and (3) adaptive practices including cover cropping and precision irrigation, studied at ISU's research farms, have mitigated yield losses by up to 15% (Johnson et al., 2024).",
    tags: ["Climate Change", "Agriculture", "Corn Yields", "Soil Science", "Sustainability"]
  },
  "What are ISU's contributions to special education policy?": {
    title: "Special Education Policy Research at ISU",
    meta: "Synthesized from 3 papers · Department: Special Education · 2017–2023",
    text: "ISU's Special Education program has produced influential policy research including: (1) a comprehensive analysis of IEP implementation fidelity across 47 Illinois districts, finding significant variance in service delivery (Park & Anderson, 2021), (2) longitudinal tracking data showing inclusive classroom models improve both academic and social outcomes for students with disabilities (Chen et al., 2023), and (3) policy recommendations adopted by the Illinois State Board of Education for transition planning for post-secondary students (Williams, 2019).",
    tags: ["Special Education", "IEP", "Inclusive Education", "Policy", "Disability Studies"]
  },
  "Summarize ISU research on cybersecurity and information systems": {
    title: "Cybersecurity & Information Systems Research",
    meta: "Synthesized from 3 papers · Department: IT · 2020–2025",
    text: "ISU's School of Information Technology has contributed to cybersecurity research through: (1) development of a novel phishing detection framework using NLP techniques that achieved 94.7% accuracy on benchmark datasets (Kumar & Zhang, 2024), (2) analysis of SMB cybersecurity postures in the Midwest, revealing that 62% of surveyed businesses lacked incident response plans (Davis, 2022), and (3) a student-led red team exercise program that has trained over 200 IT professionals in ethical hacking methodologies since 2020 (Moore et al., 2023).",
    tags: ["Cybersecurity", "Phishing Detection", "NLP", "InfoSec", "Red Team"]
  },
  "What has ISU published about community health interventions?": {
    title: "Community Health Intervention Research",
    meta: "Synthesized from 3 papers · Department: Health Sciences · 2019–2024",
    text: "ISU's Mennonite College of Nursing and Health Sciences programs have published extensively on community health: (1) a mobile health clinic initiative serving rural McLean County that increased preventive care utilization by 34% (Johnson & Rivera, 2023), (2) evaluation of a campus-based mental health first aid training that reduced stigma scores by 28% among participants (Park, 2021), and (3) a community-academic partnership model for diabetes prevention that demonstrated a 19% reduction in A1C levels among program participants over 12 months (Anderson et al., 2024).",
    tags: ["Community Health", "Mobile Clinics", "Mental Health", "Diabetes Prevention", "Nursing"]
  }
};

function showResult(query) {
  var result = demoResponses[query];
  if (!result) {
    var keys = Object.keys(demoResponses);
    result = demoResponses[keys[Math.floor(Math.random() * keys.length)]];
  }
  document.getElementById('resultTitle').textContent = result.title;
  document.getElementById('resultMeta').textContent = result.meta;
  document.getElementById('resultText').textContent = result.text;
  var tagsEl = document.getElementById('resultTags');
  tagsEl.innerHTML = result.tags.map(function(t) {
    return '<span class="demo-tag">' + t + '</span>';
  }).join('');
  var el = document.getElementById('demoResult');
  el.classList.add('active');
  el.style.animation = 'fadeUp 0.4s ease';
}

document.getElementById('demoBtn').addEventListener('click', function() {
  var q = document.getElementById('demoInput').value.trim();
  if (q) showResult(q);
});

document.getElementById('demoInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') {
    var q = this.value.trim();
    if (q) showResult(q);
  }
});

document.querySelectorAll('.demo-query-chip').forEach(function(chip) {
  chip.addEventListener('click', function() {
    var q = this.getAttribute('data-query');
    document.getElementById('demoInput').value = q;
    showResult(q);
  });
});

/* ========== ANIMATED COUNTERS ========== */
function animateCounters() {
  document.querySelectorAll('.stat-number, .hero-stat-num').forEach(function(el) {
    if (el.dataset.animated) return;
    var rect = el.getBoundingClientRect();
    if (rect.top > window.innerHeight || rect.bottom < 0) return;
    el.dataset.animated = 'true';
    var text = el.textContent.trim();
    // Only animate pure numbers
    var match = text.replace(/,/g, '').match(/^(\d+)$/);
    if (!match) return;
    var target = parseInt(match[1]);
    var duration = 1500;
    var start = performance.now();
    function update(now) {
      var elapsed = now - start;
      var progress = Math.min(elapsed / duration, 1);
      // easeOutExpo
      var eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
      var current = Math.floor(eased * target);
      el.textContent = current.toLocaleString();
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  });
}

window.addEventListener('scroll', animateCounters);
window.addEventListener('load', animateCounters);
</script>
</body>
</html>