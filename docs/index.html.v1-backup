<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ISU ReD AI — Intelligent Research Discovery Platform</title>
<meta name="description" content="AI-powered semantic search over 16,000+ research papers from Illinois State University's Research and eData repository.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&family=PT+Serif:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ========== CSS RESET & VARIABLES ========== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --isu-red: #CC0000;
  --isu-red-dark: #A00000;
  --isu-red-light: #E53333;
  --isu-yellow: #F6A917;
  --isu-yellow-light: #FCEBD0;
  --isu-blue: #56758F;
  --isu-blue-light: #7A9BB5;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F8F9FA;
  --bg-tertiary: #F0F1F3;
  --bg-card: #FFFFFF;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A5A;
  --text-muted: #7A7A8A;
  --border-color: #E2E4E8;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
  --shadow-xl: 0 20px 60px rgba(0,0,0,0.15), 0 8px 20px rgba(0,0,0,0.08);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --font-sans: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-serif: 'PT Serif', Georgia, serif;
  --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

[data-theme="dark"] {
  --bg-primary: #0D1117;
  --bg-secondary: #161B22;
  --bg-tertiary: #1C2129;
  --bg-card: #1C2129;
  --text-primary: #F0F6FC;
  --text-secondary: #C9D1D9;
  --text-muted: #8B949E;
  --border-color: #30363D;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.3);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.5);
  --shadow-xl: 0 20px 60px rgba(0,0,0,0.6);
  --isu-red-light: #FF4444;
}

/* ========== BASE ========== */
html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: var(--font-sans);
  background: var(--bg-primary);
  color: var(--text-primary);
  line-height: 1.6;
  transition: background var(--transition), color var(--transition);
  overflow-x: hidden;
}

a { color: var(--isu-red); text-decoration: none; transition: color var(--transition); }
a:hover { color: var(--isu-red-dark); }

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* ========== NAVIGATION ========== */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--border-color);
  transition: background var(--transition), border-color var(--transition);
}

[data-theme="dark"] .nav {
  background: rgba(13,17,23,0.85);
}

.nav-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 24px;
  display: flex; align-items: center; justify-content: space-between;
  height: 64px;
}

.nav-brand {
  display: flex; align-items: center; gap: 12px;
  font-weight: 700; font-size: 1.1rem; color: var(--text-primary);
}

.nav-brand-dot {
  width: 10px; height: 10px; background: var(--isu-red);
  border-radius: 50%; display: inline-block;
}

.nav-links { display: flex; align-items: center; gap: 8px; list-style: none; }

.nav-links a {
  color: var(--text-secondary); font-size: 0.875rem; font-weight: 500;
  padding: 8px 14px; border-radius: var(--radius-sm);
  transition: all var(--transition);
}

.nav-links a:hover { color: var(--isu-red); background: var(--bg-secondary); }

.theme-toggle {
  background: var(--bg-secondary); border: 1px solid var(--border-color);
  border-radius: var(--radius-sm); padding: 8px 10px;
  cursor: pointer; font-size: 1.1rem; line-height: 1;
  transition: all var(--transition); color: var(--text-primary);
}

.theme-toggle:hover { border-color: var(--isu-red); }

.nav-mobile-btn {
  display: none; background: none; border: none; cursor: pointer;
  color: var(--text-primary); font-size: 1.4rem; padding: 4px;
}

/* ========== HERO ========== */
.hero {
  padding: 140px 0 100px;
  background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  position: relative; overflow: hidden;
  transition: background var(--transition);
}

.hero::before {
  content: ''; position: absolute; top: -50%; right: -20%;
  width: 800px; height: 800px;
  background: radial-gradient(circle, rgba(204,0,0,0.06) 0%, transparent 70%);
  border-radius: 50%; pointer-events: none;
}

.hero::after {
  content: ''; position: absolute; bottom: -30%; left: -10%;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(246,169,23,0.05) 0%, transparent 70%);
  border-radius: 50%; pointer-events: none;
}

.hero-content { position: relative; z-index: 1; text-align: center; }

.hero-seal {
  width: 100px; height: 100px; margin: 0 auto 24px;
  border-radius: 50%; overflow: hidden;
  box-shadow: var(--shadow-lg);
  border: 3px solid var(--bg-card);
}

.hero-seal img { width: 100%; height: 100%; object-fit: cover; }

.hero-wordmark {
  font-family: var(--font-sans);
  font-size: 0.8rem; font-weight: 700;
  letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--isu-red); margin-bottom: 20px;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 700; line-height: 1.15;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.hero-title span { color: var(--isu-red); }

.hero-subtitle {
  font-size: clamp(1.1rem, 2vw, 1.35rem);
  color: var(--text-secondary);
  font-weight: 400; max-width: 680px; margin: 0 auto 40px;
  line-height: 1.5;
}

.hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 32px; border-radius: var(--radius-sm);
  font-family: var(--font-sans); font-size: 0.95rem; font-weight: 600;
  cursor: pointer; transition: all var(--transition); border: none;
  text-decoration: none;
}

.btn-primary {
  background: var(--isu-red); color: #FFF;
  box-shadow: 0 4px 14px rgba(204,0,0,0.35);
}

.btn-primary:hover {
  background: var(--isu-red-dark); color: #FFF;
  box-shadow: 0 6px 20px rgba(204,0,0,0.45);
  transform: translateY(-2px);
}

.btn-secondary {
  background: var(--bg-card); color: var(--text-primary);
  border: 1px solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.btn-secondary:hover {
  border-color: var(--isu-red); color: var(--isu-red);
  transform: translateY(-2px); box-shadow: var(--shadow-md);
}

.hero-stats-bar {
  margin-top: 60px;
  display: flex; justify-content: center; gap: 48px; flex-wrap: wrap;
}

.hero-stat { text-align: center; }
.hero-stat-num {
  font-size: 1.5rem; font-weight: 800; color: var(--isu-red);
  font-variant-numeric: tabular-nums;
}
.hero-stat-label {
  font-size: 0.75rem; color: var(--text-muted);
  text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;
}

/* ========== SECTIONS ========== */
.section { padding: 100px 0; }
.section-alt { background: var(--bg-secondary); }

.section-header {
  text-align: center; margin-bottom: 64px;
}

.section-label {
  display: inline-block; font-size: 0.75rem; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--isu-red); margin-bottom: 12px;
  background: rgba(204,0,0,0.08); padding: 6px 16px;
  border-radius: 100px;
}

[data-theme="dark"] .section-label { background: rgba(204,0,0,0.15); }

.section-title {
  font-family: var(--font-serif);
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  font-weight: 700; color: var(--text-primary);
  margin-bottom: 16px;
}

.section-desc {
  font-size: 1.05rem; color: var(--text-secondary);
  max-width: 640px; margin: 0 auto;
}

/* ========== ARCHITECTURE ========== */
.pipeline {
  display: flex; align-items: stretch; justify-content: center;
  gap: 0; flex-wrap: wrap; margin: 0 auto;
  max-width: 1100px;
}

.pipeline-step {
  flex: 1; min-width: 150px; max-width: 180px;
  text-align: center; position: relative;
  padding: 28px 16px;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  transition: all var(--transition);
  margin: 0 24px 16px 0;
}

.pipeline-step:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--isu-red);
}

.pipeline-step:not(:last-child)::after {
  content: '→'; position: absolute;
  right: -22px; top: 50%;
  transform: translateY(-50%);
  font-size: 1.4rem; font-weight: 300;
  color: var(--isu-red);
}

.pipeline-step:last-child { margin-right: 0; }

.pipeline-icon {
  width: 52px; height: 52px; margin: 0 auto 14px;
  background: rgba(204,0,0,0.08);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem;
  transition: background var(--transition);
}

[data-theme="dark"] .pipeline-icon { background: rgba(204,0,0,0.15); }

.pipeline-step:hover .pipeline-icon { background: rgba(204,0,0,0.15); }

.pipeline-label {
  font-size: 0.85rem; font-weight: 700;
  color: var(--text-primary); margin-bottom: 6px;
}

.pipeline-detail {
  font-size: 0.72rem; color: var(--text-muted);
  line-height: 1.4;
}

/* ========== STATS GRID ========== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px;
}

.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 32px 28px;
  transition: all var(--transition);
  position: relative; overflow: hidden;
}

.stat-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 3px; background: var(--isu-red);
  transform: scaleX(0); transform-origin: left;
  transition: transform var(--transition);
}

.stat-card:hover::before { transform: scaleX(1); }

.stat-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.stat-number {
  font-size: 2.2rem; font-weight: 800;
  color: var(--isu-red); line-height: 1.1;
  margin-bottom: 4px;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  font-size: 0.95rem; font-weight: 600;
  color: var(--text-primary); margin-bottom: 8px;
}

.stat-desc {
  font-size: 0.82rem; color: var(--text-muted);
  line-height: 1.5;
}

/* ========== FEATURES ========== */
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 28px;
}

.feature-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 36px 32px;
  transition: all var(--transition);
}

.feature-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: transparent;
}

.feature-icon {
  width: 48px; height: 48px;
  background: linear-gradient(135deg, var(--isu-red), var(--isu-red-light));
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem; margin-bottom: 20px;
  color: #FFF;
}

.feature-title {
  font-size: 1.1rem; font-weight: 700;
  color: var(--text-primary); margin-bottom: 10px;
}

.feature-desc {
  font-size: 0.9rem; color: var(--text-secondary);
  line-height: 1.6;
}

/* ========== TECH STACK ========== */
.tech-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
}

.tech-item {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24px 20px;
  display: flex; align-items: flex-start; gap: 14px;
  transition: all var(--transition);
}

.tech-item:hover {
  border-color: var(--isu-red);
  box-shadow: var(--shadow-md);
}

.tech-icon {
  width: 36px; height: 36px; flex-shrink: 0;
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
}

.tech-name { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); }
.tech-role { font-size: 0.78rem; color: var(--text-muted); }

/* ========== COST ANALYSIS ========== */
.cost-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 32px; max-width: 900px; margin: 0 auto;
}

.cost-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 40px 36px;
  text-align: center;
  transition: all var(--transition);
}

.cost-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-4px); }

.cost-card.highlight {
  border-color: var(--isu-red);
  background: linear-gradient(135deg, rgba(204,0,0,0.03), rgba(246,169,23,0.03));
}

[data-theme="dark"] .cost-card.highlight {
  background: linear-gradient(135deg, rgba(204,0,0,0.08), rgba(246,169,23,0.05));
}

.cost-eyebrow {
  font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.15em; color: var(--text-muted); margin-bottom: 12px;
}

.cost-amount {
  font-size: 3rem; font-weight: 800;
  color: var(--text-primary); line-height: 1;
  margin-bottom: 4px;
}

.cost-card.highlight .cost-amount { color: var(--isu-red); }

.cost-sub {
  font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 20px;
}

.cost-breakdown {
  list-style: none; text-align: left;
  font-size: 0.85rem; color: var(--text-secondary);
}

.cost-breakdown li {
  padding: 6px 0;
  border-bottom: 1px solid var(--border-color);
  display: flex; justify-content: space-between;
}

.cost-breakdown li:last-child { border-bottom: none; }

.savings-badge {
  display: inline-block; margin-top: 20px;
  background: rgba(204,0,0,0.1); color: var(--isu-red);
  font-weight: 700; font-size: 0.85rem;
  padding: 8px 20px; border-radius: 100px;
}

[data-theme="dark"] .savings-badge { background: rgba(204,0,0,0.2); }

/* ========== SEARCH DEMO ========== */
.demo-section { padding: 100px 0; }

.demo-container {
  max-width: 720px; margin: 0 auto;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-xl);
  padding: 48px 40px;
  box-shadow: var(--shadow-lg);
}

.demo-search-wrap {
  display: flex; gap: 12px; margin-bottom: 24px;
}

.demo-input {
  flex: 1; padding: 14px 20px;
  border: 2px solid var(--border-color);
  border-radius: var(--radius-sm);
  font-family: var(--font-sans);
  font-size: 0.95rem;
  background: var(--bg-secondary);
  color: var(--text-primary);
  transition: all var(--transition);
  outline: none;
}

.demo-input:focus { border-color: var(--isu-red); box-shadow: 0 0 0 3px rgba(204,0,0,0.1); }
.demo-input::placeholder { color: var(--text-muted); }

.demo-btn {
  padding: 14px 28px; background: var(--isu-red);
  color: #FFF; border: none; border-radius: var(--radius-sm);
  font-family: var(--font-sans); font-size: 0.95rem; font-weight: 600;
  cursor: pointer; transition: all var(--transition);
  white-space: nowrap;
}

.demo-btn:hover { background: var(--isu-red-dark); }

.demo-queries {
  display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px;
}

.demo-query-chip {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 100px;
  padding: 6px 16px;
  font-size: 0.8rem; color: var(--text-secondary);
  cursor: pointer; transition: all var(--transition);
}

.demo-query-chip:hover {
  border-color: var(--isu-red); color: var(--isu-red);
  background: rgba(204,0,0,0.05);
}

.demo-result {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24px;
  display: none;
}

.demo-result.active { display: block; }

.demo-result-header {
  font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.15em; color: var(--isu-red); margin-bottom: 12px;
}

.demo-result-title {
  font-family: var(--font-serif);
  font-size: 1.1rem; font-weight: 700;
  color: var(--text-primary); margin-bottom: 8px;
}

.demo-result-meta {
  font-size: 0.78rem; color: var(--text-muted); margin-bottom: 12px;
}

.demo-result-text {
  font-size: 0.88rem; color: var(--text-secondary); line-height: 1.65;
}

.demo-result-tags {
  display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px;
}

.demo-tag {
  background: rgba(204,0,0,0.08); color: var(--isu-red);
  font-size: 0.7rem; font-weight: 600;
  padding: 3px 10px; border-radius: 100px;
}

[data-theme="dark"] .demo-tag { background: rgba(204,0,0,0.18); }

/* ========== API / GETTING STARTED ========== */
.api-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 24px;
}

.api-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: all var(--transition);
}

.api-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }

.api-card-header {
  padding: 20px 24px;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border-color);
  display: flex; align-items: center; gap: 10px;
}

.api-method {
  font-size: 0.7rem; font-weight: 800;
  padding: 3px 10px; border-radius: 4px;
  text-transform: uppercase; letter-spacing: 0.05em;
}

.api-method.get { background: #D4EDDA; color: #155724; }
.api-method.post { background: #CCE5FF; color: #004085; }

[data-theme="dark"] .api-method.get { background: #1A3A2A; color: #7DD39F; }
[data-theme="dark"] .api-method.post { background: #1A2E45; color: #79B8FF; }

.api-path {
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 0.85rem; color: var(--text-primary); font-weight: 600;
}

.api-card-body { padding: 20px 24px; }

.api-desc { font-size: 0.88rem; color: var(--text-secondary); margin-bottom: 14px; }

.api-code {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 14px 18px;
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 0.78rem;
  color: var(--text-primary);
  overflow-x: auto;
  white-space: pre;
  line-height: 1.6;
}

/* ========== FOOTER ========== */
.footer {
  background: var(--bg-secondary);
  border-top: 1px solid var(--border-color);
  padding: 60px 0 40px;
  text-align: center;
  transition: background var(--transition), border-color var(--transition);
}

.footer-seal {
  width: 64px; height: 64px; margin: 0 auto 16px;
  border-radius: 50%; overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.footer-seal img { width: 100%; height: 100%; object-fit: cover; }

.footer-org {
  font-size: 0.85rem; font-weight: 700;
  color: var(--text-primary); margin-bottom: 4px;
}

.footer-dept {
  font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 20px;
}

.footer-powered {
  font-size: 0.75rem; color: var(--text-muted);
  background: var(--bg-tertiary);
  display: inline-block;
  padding: 6px 18px; border-radius: 100px;
  margin-bottom: 20px;
}

.footer-credits {
  font-size: 0.75rem; color: var(--text-muted); margin-bottom: 4px;
}

.footer-copy {
  font-size: 0.7rem; color: var(--text-muted);
}

/* ========== RESPONSIVE ========== */
@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-mobile-btn { display: block; }
  .nav-links.open {
    display: flex; flex-direction: column;
    position: absolute; top: 64px; left: 0; right: 0;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    padding: 16px 24px;
  }
  .hero { padding: 120px 0 80px; }
  .hero-stats-bar { gap: 24px; }
  .pipeline-step { max-width: 140px; margin: 0 16px 16px 0; }
  .pipeline-step:not(:last-child)::after { right: -16px; font-size: 1rem; }
  .cost-grid { grid-template-columns: 1fr; }
  .demo-container { padding: 32px 24px; }
  .demo-search-wrap { flex-direction: column; }
  .features-grid { grid-template-columns: 1fr; }
  .api-grid { grid-template-columns: 1fr; }
}

@media (max-width: 500px) {
  .pipeline { flex-direction: column; align-items: center; }
  .pipeline-step { max-width: 240px; margin: 0 0 16px 0; }
  .pipeline-step:not(:last-child)::after {
    content: '↓'; right: auto; bottom: -18px; top: auto;
    left: 50%; transform: translateX(-50%);
  }
}

/* ========== ANIMATIONS ========== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
.animate.visible { opacity: 1; transform: translateY(0); }

/* ========== SCROLL PROGRESS ========== */
.scroll-progress {
  position: fixed; top: 64px; left: 0; height: 2px;
  background: var(--isu-red); z-index: 999;
  width: 0; transition: width 0.1s linear;
}
</style>
</head>
